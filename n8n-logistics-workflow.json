    {
      "parameters": {
        "jsCode": "// Convertir el attachment base64 a binario para que Gmail pueda adjuntarlo\nconst item = $input.first();\nconst attachment = item.json.attachment;\n\nif (attachment && attachment.contentBase64) {\n  const binaryData = Buffer.from(attachment.contentBase64, 'base64');\n  \n  return [{\n    json: item.json,\n    binary: {\n      attachment: {\n        data: binaryData.toString('base64'),\n        mimeType: attachment.contentType,\n        fileName: attachment.filename,\n      }\n    }\n  }];\n}\n\n// Si no hay attachment, pasar el item sin cambios\nreturn [$input.first()];"
      },
